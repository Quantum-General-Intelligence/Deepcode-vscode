{
  "name": "takedeep",
  "displayName": "TakeDeep: AI Coding Agent",
  "description": "TakeDeep AI coding agent â€” generate code from natural language, automate tasks, and run terminal commands. Supports Claude, Gemini, GPT, and custom providers via deeper-api.takedeep.ai.",
  "version": "7.2.31",
  "icon": "assets/icons/logo-outline-black.png",
  "galleryBanner": {
    "color": "#FFFFFF",
    "theme": "light"
  },
  "publisher": "takedeep",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kilo-Org/kilocode.git",
    "directory": "packages/kilo-vscode"
  },
  "engines": {
    "vscode": "^1.105.1"
  },
  "license": "MIT",
  "author": {
    "name": "TakeDeep"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education",
    "Snippets",
    "Testing"
  ],
  "keywords": [
    "takedeep",
    "deeper",
    "claude",
    "dev",
    "mcp",
    "openrouter",
    "coding",
    "agent",
    "autonomous",
    "chatgpt",
    "sonnet",
    "ai",
    "llama",
    "TakeDeep"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "taskDefinitions": [
      {
        "type": "takedeep-worktree-setup",
        "properties": {
          "script": {
            "type": "string",
            "description": "The setup script command to execute"
          }
        }
      }
    ],
    "icons": {
      "takedeep-logo": {
        "description": "TakeDeep logo",
        "default": {
          "fontPath": "assets/icons/kilo-icon-font.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "takedeep-ActivityBar",
          "title": "TakeDeep",
          "icon": "assets/icons/takedeep-activitybar.png",
          "darkIcon": "assets/icons/takedeep-activitybar.png"
        }
      ]
    },
    "views": {
      "takedeep-ActivityBar": [
        {
          "type": "webview",
          "id": "takedeep.SidebarProvider",
          "name": "TakeDeep"
        }
      ]
    },
    "commands": [
      {
        "command": "takedeep.plusButtonClicked",
        "title": "New Task",
        "icon": "$(add)"
      },
      {
        "command": "takedeep.agentManagerOpen",
        "title": "Agent Manager",
        "icon": "$(organization)"
      },
      {
        "command": "takedeep.marketplaceButtonClicked",
        "title": "Marketplace",
        "icon": "$(extensions)"
      },
      {
        "command": "takedeep.historyButtonClicked",
        "title": "History",
        "icon": "$(history)"
      },
      {
        "command": "takedeep.profileButtonClicked",
        "title": "Profile",
        "icon": "$(account)"
      },
      {
        "command": "takedeep.settingsButtonClicked",
        "title": "Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "takedeep.openInTab",
        "title": "TakeDeep",
        "icon": {
          "light": "assets/icons/kilo-light.svg",
          "dark": "assets/icons/kilo-dark.svg"
        }
      },
      {
        "command": "takedeep.showChanges",
        "title": "Show Changes",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.openMigrationWizard",
        "title": "Migrate Settings from Legacy Version",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.autocomplete.generateSuggestions",
        "title": "Generate Suggested Edits",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.autocomplete.cancelSuggestions",
        "title": "Cancel Suggested Edits",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.previousSession",
        "title": "Agent Manager: Previous Session",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.nextSession",
        "title": "Agent Manager: Next Session",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.previousTab",
        "title": "Agent Manager: Previous Tab",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.nextTab",
        "title": "Agent Manager: Next Tab",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.showTerminal",
        "title": "Agent Manager: Focus Terminal",
        "category": "TakeDeep",
        "icon": "$(terminal)"
      },
      {
        "command": "takedeep.agentManager.runScript",
        "title": "Agent Manager: Run Script",
        "category": "TakeDeep",
        "icon": "$(play)"
      },
      {
        "command": "takedeep.agentManager.toggleDiff",
        "title": "Agent Manager: Toggle Diff Panel",
        "category": "TakeDeep",
        "icon": "$(diff)"
      },
      {
        "command": "takedeep.agentManager.showShortcuts",
        "title": "Agent Manager: Show Keyboard Shortcuts",
        "category": "TakeDeep",
        "icon": "$(keyboard)"
      },
      {
        "command": "takedeep.agentManager.newTab",
        "title": "Agent Manager: New Tab",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.newTerminal",
        "title": "Agent Manager: New Terminal Tab (Experimental)",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.closeTab",
        "title": "Agent Manager: Close Tab",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.newWorktree",
        "title": "Agent Manager: New Worktree",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.openWorktree",
        "title": "Agent Manager: Open Worktree",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.closeWorktree",
        "title": "Agent Manager: Close Worktree",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.advancedWorktree",
        "title": "Agent Manager: Advanced New Worktree",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.jumpTo1",
        "title": "Agent Manager: Jump to Item 1",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.jumpTo2",
        "title": "Agent Manager: Jump to Item 2",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.jumpTo3",
        "title": "Agent Manager: Jump to Item 3",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.jumpTo4",
        "title": "Agent Manager: Jump to Item 4",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.jumpTo5",
        "title": "Agent Manager: Jump to Item 5",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.jumpTo6",
        "title": "Agent Manager: Jump to Item 6",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.jumpTo7",
        "title": "Agent Manager: Jump to Item 7",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.jumpTo8",
        "title": "Agent Manager: Jump to Item 8",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.agentManager.jumpTo9",
        "title": "Agent Manager: Jump to Item 9",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.generateCommitMessage",
        "title": "Generate Commit Message",
        "category": "TakeDeep",
        "icon": {
          "light": "assets/icons/kilo-light.svg",
          "dark": "assets/icons/kilo-dark.svg"
        }
      },
      {
        "command": "takedeep.explainCode",
        "title": "Explain Code",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.fixCode",
        "title": "Fix Code",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.improveCode",
        "title": "Improve Code",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.addToContext",
        "title": "Add to Context",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.terminalAddToContext",
        "title": "Add Terminal Content to Context",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.terminalFixCommand",
        "title": "Fix This Command",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.terminalExplainCommand",
        "title": "Explain This Command",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.focusChatInput",
        "title": "Focus Chat Input",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.cycleAgentMode",
        "title": "Cycle Agent Mode",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.cyclePreviousAgentMode",
        "title": "Cycle Previous Agent Mode",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.toggleAutoApprove",
        "title": "Toggle Auto-Approve",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.generateTerminalCommand",
        "title": "Generate Terminal Command",
        "category": "TakeDeep"
      },
      {
        "command": "takedeep.takeHeapSnapshot",
        "title": "Take Heap Snapshot",
        "category": "TakeDeep"
      }
    ],
    "submenus": [
      {
        "id": "takedeep.editorContextMenu",
        "label": "TakeDeep"
      },
      {
        "id": "takedeep.terminalContextMenu",
        "label": "TakeDeep"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "takedeep.plusButtonClicked",
          "group": "navigation@0",
          "when": "view == takedeep.SidebarProvider"
        },
        {
          "command": "takedeep.historyButtonClicked",
          "group": "navigation@1",
          "when": "view == takedeep.SidebarProvider"
        },
        {
          "command": "takedeep.agentManagerOpen",
          "group": "navigation@2",
          "when": "view == takedeep.SidebarProvider"
        },
        {
          "command": "takedeep.marketplaceButtonClicked",
          "group": "navigation@4",
          "when": "view == takedeep.SidebarProvider"
        },
        {
          "command": "takedeep.profileButtonClicked",
          "group": "navigation@5",
          "when": "view == takedeep.SidebarProvider"
        },
        {
          "command": "takedeep.settingsButtonClicked",
          "group": "navigation@6",
          "when": "view == takedeep.SidebarProvider"
        }
      ],
      "scm/title": [
        {
          "command": "takedeep.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "scm/input": [
        {
          "command": "takedeep.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "editor/title": [
        {
          "command": "takedeep.openInTab",
          "group": "navigation",
          "when": "true"
        },
        {
          "command": "takedeep.plusButtonClicked",
          "group": "navigation@0",
          "when": "activeWebviewPanelId == takedeep.TabPanel"
        },
        {
          "command": "takedeep.historyButtonClicked",
          "group": "navigation@1",
          "when": "activeWebviewPanelId == takedeep.TabPanel"
        },
        {
          "command": "takedeep.profileButtonClicked",
          "group": "navigation@2",
          "when": "activeWebviewPanelId == takedeep.TabPanel"
        },
        {
          "command": "takedeep.settingsButtonClicked",
          "group": "navigation@3",
          "when": "activeWebviewPanelId == takedeep.TabPanel"
        }
      ],
      "editor/context": [
        {
          "submenu": "takedeep.editorContextMenu",
          "group": "1_takedeep"
        }
      ],
      "takedeep.editorContextMenu": [
        {
          "command": "takedeep.explainCode",
          "group": "1_actions@1"
        },
        {
          "command": "takedeep.fixCode",
          "group": "1_actions@2"
        },
        {
          "command": "takedeep.improveCode",
          "group": "1_actions@3"
        },
        {
          "command": "takedeep.addToContext",
          "group": "1_actions@4"
        }
      ],
      "terminal/context": [
        {
          "submenu": "takedeep.terminalContextMenu",
          "group": "2_takedeep"
        }
      ],
      "takedeep.terminalContextMenu": [
        {
          "command": "takedeep.terminalAddToContext",
          "group": "1_actions@1"
        },
        {
          "command": "takedeep.terminalFixCommand",
          "group": "1_actions@2"
        },
        {
          "command": "takedeep.terminalExplainCommand",
          "group": "1_actions@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "takedeep.focusChatInput",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "takedeep.toggleAutoApprove",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "takedeep.generateTerminalCommand",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "takedeep.agentManagerOpen",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "takedeep.addToContext",
        "key": "ctrl+k ctrl+a",
        "mac": "cmd+k cmd+a",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "takedeep.agentManager.previousSession",
        "key": "ctrl+alt+up",
        "mac": "cmd+alt+up",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.nextSession",
        "key": "ctrl+alt+down",
        "mac": "cmd+alt+down",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.previousTab",
        "key": "ctrl+alt+left",
        "mac": "cmd+alt+left",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.nextTab",
        "key": "ctrl+alt+right",
        "mac": "cmd+alt+right",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.showTerminal",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.runScript",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel' && (isMac || !terminalFocus)"
      },
      {
        "command": "takedeep.agentManager.toggleDiff",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.showShortcuts",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.newTab",
        "key": "ctrl+t",
        "mac": "cmd+t",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.newTerminal",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.closeTab",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.newWorktree",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.openWorktree",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.closeWorktree",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.advancedWorktree",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.jumpTo1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.jumpTo2",
        "key": "ctrl+2",
        "mac": "cmd+2",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.jumpTo3",
        "key": "ctrl+3",
        "mac": "cmd+3",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.jumpTo4",
        "key": "ctrl+4",
        "mac": "cmd+4",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.jumpTo5",
        "key": "ctrl+5",
        "mac": "cmd+5",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.jumpTo6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.jumpTo7",
        "key": "ctrl+7",
        "mac": "cmd+7",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.jumpTo8",
        "key": "ctrl+8",
        "mac": "cmd+8",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.agentManager.jumpTo9",
        "key": "ctrl+9",
        "mac": "cmd+9",
        "when": "activeWebviewPanelId == 'takedeep.AgentManagerPanel'"
      },
      {
        "command": "takedeep.cycleAgentMode",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "sideBarFocus && takedeep.sidebarVisible || activeWebviewPanelId == 'takedeep.AgentManagerPanel' || activeWebviewPanelId == 'takedeep.TabPanel'"
      },
      {
        "command": "takedeep.cyclePreviousAgentMode",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "sideBarFocus && takedeep.sidebarVisible || activeWebviewPanelId == 'takedeep.AgentManagerPanel' || activeWebviewPanelId == 'takedeep.TabPanel'"
      },
      {
        "command": "takedeep.autocomplete.cancelSuggestions",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && takedeep.autocomplete.hasSuggestions"
      },
      {
        "command": "takedeep.autocomplete.generateSuggestions",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && takedeep.autocomplete.enableSmartInlineTaskKeybinding && !github.copilot.completions.enabled"
      },
      {
        "command": "takedeep.autocomplete.showIncompatibilityExtensionPopup",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && takedeep.autocomplete.enableSmartInlineTaskKeybinding && github.copilot.completions.enabled"
      }
    ],
    "configuration": {
      "title": "TakeDeep",
