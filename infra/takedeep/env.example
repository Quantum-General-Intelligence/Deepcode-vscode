# TakeDeep production — copy to /opt/takedeep/.env on symboliq-g6x16

TAKEDEEP_API_URL=https://deeper-api.takedeep.ai
TAKEDEEP_DASH_URL=https://deeper-dash.takedeep.ai
TAKEDEEP_WEB_URL=https://deeper.takedeep.ai
TAKEDEEP_API_PORT=8787
TAKEDEEP_DASH_PORT=8788
TAKEDEEP_DB_PATH=/var/lib/takedeep/takedeep.db
TAKEDEEP_JWT_SECRET=change-me
TAKEDEEP_ADMIN_EMAIL=sam@sammane.com
TAKEDEEP_DEVICE_CODE_TTL_SEC=900

# LiteLLM (Tailscale — Qualtron)
LITELLM_QUALTRON_URL=http://100.67.97.49:4000
LITELLM_QUALTRON_MASTER_KEY=

# Stripe TheoSym
STRIPE_THEOSYM_SECRET_KEY=
STRIPE_THEOSYM_WEBHOOK_SECRET=

# deeper serve (web UI backend) — HTTP Basic auth user is `kilo`
KILO_SERVER_PASSWORD=

# Cloudflare tunnel token for symboliq-g6x16 (create in Zero Trust)
CF_TUNNEL_SYMBOLIQ_TOKEN=
